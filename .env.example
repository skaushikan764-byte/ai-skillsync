# AI SkillSync - Environment Variables
# Copy this file to .env and fill in your values

# Database - SQLite (default, works out of the box)
DATABASE_URL=sqlite:///./skillsync.db

# Optional: PostgreSQL (uncomment and modify if needed)
# DATABASE_URL=postgresql+psycopg2://username:password@host:port/databasename

# Optional: MySQL (uncomment and modify if needed)
# DATABASE_URL=mysql+pymysql://username:password@host:port/databasename
